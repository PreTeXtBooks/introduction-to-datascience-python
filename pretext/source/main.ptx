<?xml version='1.0' encoding='utf-8'?>
<!-- This is the main file of the pretext template book provided -->
<!-- by the <c>pretext new book</c> command.  The main.ptx here always-->
<!-- starts with <pretext> tags.  In this example, the main file -->
<!-- just imports other .ptx files which contain content. Open   -->
<!-- those files to see more pretext features                    -->

<pretext xml:lang="en-US" xmlns:xi="http://www.w3.org/2001/XInclude">

  <!-- we first include a file which contains the docinfo element: -->
  <xi:include href="./meta_docinfo.ptx" />

  <!-- The <book> tags wrap all the content.  Change the @xml:id   -->
  <!-- to some short (non-spaced) description of your book         -->
  <book xml:id="introduction-to-datascience">
    <!-- The book needs a title and can have a subtitle  -->
    <title>Data Science</title>
    <subtitle>A First Introduction</subtitle>

    <!-- Now we include files containing each main devision.       -->

    <!-- First a frontmatter for prefaces and such. Maybe comment  -->
    <!-- out for now and write this when the book is more complete -->
    <xi:include href="./meta_frontmatter.ptx" />

    <!-- Chapter 1: Python and Pandas -->
    <xi:include href="./ch_intro.ptx" />

    <!-- Chapter 2: Reading in data locally and from the web -->
    <xi:include href="./ch_reading.ptx" />

    <!-- Chapter 3: Cleaning and wrangling data -->
    <xi:include href="./ch_wrangling.ptx" />

    <!-- Chapter 4: Effective data visualization -->
    <xi:include href="./ch_viz.ptx" />

    <!-- Chapter 5: Classification I: training and predicting -->
    <xi:include href="./ch_classification1.ptx" />

    <!-- Chapter 6: Classification II: evaluation and tuning -->
    <xi:include href="./ch_classification2.ptx" />

    <!-- Chapter 7: Regression I: K-nearest neighbors -->
    <xi:include href="./ch_regression1.ptx" />

    <!-- Chapter 8: Regression II: linear regression -->
    <xi:include href="./ch_regression2.ptx" />

    <!-- Chapter 9: Clustering -->
    <xi:include href="./ch_clustering.ptx" />

    <!-- Chapter 10: Statistical inference -->
    <xi:include href="./ch_inference.ptx" />

    <!-- Chapter 11: Combining code and text with Jupyter -->
    <xi:include href="./ch_jupyter.ptx" />

    <!-- Chapter 12: Collaboration with version control -->
    <xi:include href="./ch_version_control.ptx" />

    <!-- Chapter 13: Setting up your computer -->
    <xi:include href="./ch_setup.ptx" />

    <!-- Backmatter: references and index -->
    <xi:include href="./meta_backmatter.ptx" />
  </book>
</pretext>
